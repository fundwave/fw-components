{
  "name": "fw-components",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "format": "prettier --check",
    "format:fix": "prettier --write",
    "lint": "eslint --cache",
    "lint:fix": "eslint --cache --fix",
    "lint:branch": "npx lint-staged --diff origin/main --allow-empty",
    "tsc:check": "tscw --noEmit",
    "clean": "lerna clean --yes && lerna run clean",
    "preinstall": "npm run clean",
    "postinstall": "lerna bootstrap --ci",
    "build": "lerna run build",
    "test": "lerna run test",
    "publish": "lerna publish",
    "prepare": "npm run setup-git-hooks",
    "setup-git-hooks": "git config core.hooksPath .hooks"
  },
  "devDependencies": {
    "lerna": "^6.6.2",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsdoc": "^50.6.17",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "globals": "^16.2.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "tscw-config": "^1.1.2",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.33.0"
  },
  "lint-staged": {
    "*.{jsx,js}": [
      "npm run lint:fix",
      "npm run format:fix"
    ],
    "*.{tsx,ts}": [
      "npm run lint:fix",
      "npm run format:fix",
      "npm run tsc:check -- -p ./tsconfig.json"
    ],
    "!(*.jsx|*.tsx|*.js|*.ts)": [
      "npm run format:fix"
    ]
  }
}
